# Server port (local desktop default)
PORT=3000

# Comma-separated CORS allowlist
# Local frontend defaults:
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional backup settings
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_MINUTES=60
AUTO_BACKUP_RUN_ON_START=false
AUTO_BACKUP_RETENTION_COUNT=30

# Optional Google Drive backup target folder
# GOOGLE_DRIVE_BACKUP_DIR=C:/path/to/google-drive/folder

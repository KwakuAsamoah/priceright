{
  "name": "priceright",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npx tsc -p tsconfig.json",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run build:client && npm run build:server && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.10"
  }
}

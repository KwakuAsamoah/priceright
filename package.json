{
  "name": "priceright",
  "version": "1.0.37",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npx tsc -p tsconfig.json && node -e \"require('fs').writeFileSync('../server-dist/package.json', JSON.stringify({type:'module'}))\"",
    "generate:templates": "node scripts/generate-templates.js",
    "generate:icon": "node electron/generate-icon.js",
    "rebuild:native": "node scripts/install-electron-sqlite.js",
    "rebuild:server-dev": "npm rebuild better-sqlite3 --prefix server",
    "verify:electron-native": "node scripts/verify-packaged-native.js",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run rebuild:native && npm run build:client && npm run build:server && electron-builder",
    "electron:publish": "npm run electron:build -- --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-machine-id": "^1.1.12",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.10"
  }
}
